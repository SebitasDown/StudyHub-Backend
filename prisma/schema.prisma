generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ProfessionalLevel {
  STUDENT
  INTERN
  JUNIOR
  MID
  SENIOR
}

enum Modality {
  ON_SITE
  REMOTE
  HYBRID
}

enum Availability {
  FULL_TIME
  PART_TIME
  FREELANCE
  NOT_AVAILABLE
}

enum SkillLevel {
  BASIC
  INTERMEDIATE
  ADVANCED
  EXPERT
}

enum UserRole {
  USER
  ADMIN
}

enum JobApplicationStatus {
  SAVED
  APPLIED
  INTERVIEW
  REJECTED
  HIRED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  OVERDUE
}

enum XpActionType {
  CREATE_SUBJECT
  CREATE_TASK
  COMPLETE_TASK
  CREATE_NOTE
  COMPLETE_PROFILE
  DAILY_STREAK
  ACHIEVEMENT_UNLOCK
}

enum AchievementCategory {
  TASK
  NOTE
  SUBJECT
  STREAK
  PROFILE
  CV
  JOB
}

enum AccessActionType {
  LOGIN
  LOGOUT
  REGISTER
  PASSWORD_CHANGE
  EMAIL_CHANGE
  PROFILE_UPDATE
  TWO_FA_ENABLE
  TWO_FA_DISABLE
}

model User {
  id                   Int                   @id @default(autoincrement())
  nombre               String
  apellido             String
  email                String                @unique
  password             String?
  googleId             String?               @unique
  username             String?               @unique
  role                 UserRole              @default(USER)
  isActive             Boolean               @default(true)
  isBanned             Boolean               @default(false)
  foto                 String?
  banner               String?
  avatarPublicId       String?
  bannerPublicId       String?
  ciudad               String?
  pais                 String?
  fechaNacimiento      DateTime?
  biografia            String?
  github               String?
  linkedin             String?
  portafolio           String?
  paginaPersonal       String?
  telefono             String?
  twoFactorEnabled     Boolean               @default(false)
  twoFactorSecret      String?
  emailVerified        Boolean               @default(false)
  verificationTokens   VerificationToken[]
  notificationSettings NotificationSettings?
  privacySettings      PrivacySettings?
  profile              AcademicProfile?
  professionalProfile  ProfessionalProfile?
  skills               UserSkill[]
  objectives           UserObjective[]
  modules              UserModule[]
  sessions             UserSession[]
  accessLogs           UserAccessLog[]
  subjects             Subject[]
  progress             UserProgress?
  streak               StudyStreak?
  achievements         UserAchievement[]
  xpHistory            XpHistory[]
  resume               Resume?
  resumeAnalyses       ResumeAnalysis[]
  roadmaps             Roadmap[]
  savedJobs            SavedJob[]
  jobApplications      JobApplication[]
  discoveredJobs       Job[]                 @relation("JobDiscoverer")
  createdGroups        StudyGroup[]          @relation("GroupCreator")
  groupMemberships     StudyGroupMember[]
  notifications        Notification[]
  academicRisks        AcademicRisk[]
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  groupMessages        GroupMessage[]

  @@map("users")
}

model NotificationSettings {
  id               Int     @id @default(autoincrement())
  userId           Int     @unique
  emailEnabled     Boolean @default(true)
  pushEnabled      Boolean @default(true)
  remindersEnabled Boolean @default(true)
  user             User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_settings")
}

model PrivacySettings {
  id            Int     @id @default(autoincrement())
  userId        Int     @unique
  publicProfile Boolean @default(false)
  showSkills    Boolean @default(true)
  showCV        Boolean @default(false)
  user          User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("privacy_settings")
}

model UserSession {
  id           Int      @id @default(autoincrement())
  userId       Int
  refreshToken String?
  deviceInfo   String?
  ipAddress    String?
  lastActiveAt DateTime @default(now())
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_sessions")
}

model VerificationToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  type      String
  expiresAt DateTime
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("verification_tokens")
}

model UserAccessLog {
  id         Int              @id @default(autoincrement())
  userId     Int
  actionType AccessActionType
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime         @default(now())
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_access_logs")
}

model AppModule {
  id            Int          @id @default(autoincrement())
  nombre        String       @unique
  slug          String       @unique
  icon          String?
  activoDefecto Boolean      @default(false)
  users         UserModule[]
  createdAt     DateTime     @default(now())

  @@map("app_modules")
}

model UserModule {
  userId   Int
  moduleId Int
  enabled  Boolean   @default(true)
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  module   AppModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@id([userId, moduleId])
  @@map("user_modules")
}

model Objective {
  id        Int             @id @default(autoincrement())
  nombre    String          @unique
  icon      String?
  users     UserObjective[]
  createdAt DateTime        @default(now())

  @@map("objectives")
}

model UserObjective {
  userId      Int
  objectiveId Int
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  objective   Objective @relation(fields: [objectiveId], references: [id], onDelete: Cascade)

  @@id([userId, objectiveId])
  @@map("user_objectives")
}

model Skill {
  id        Int         @id @default(autoincrement())
  nombre    String      @unique
  users     UserSkill[]
  createdAt DateTime    @default(now())

  @@map("skills")
}

model UserSkill {
  userId  Int
  skillId Int
  nivel   SkillLevel?
  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  skill   Skill       @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([userId, skillId])
  @@map("user_skills")
}

model AcademicProfile {
  id              Int      @id @default(autoincrement())
  userId          Int      @unique
  universidad     String
  carrera         String
  facultad        String
  semestreActual  Int
  fechaInicio     DateTime
  fechaGraduacion DateTime
  modalidad       Modality
  promedio        Float?
  materiasFav     String[] @default([])
  materiasDificil String[] @default([])
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("academic_profiles")
}

model ProfessionalProfile {
  id               Int               @id @default(autoincrement())
  userId           Int               @unique
  cargoDeseado     String
  nivelActual      ProfessionalLevel
  disponibilidad   Availability
  modalidadDeseada Modality
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@map("professional_profiles")
}

model Subject {
  id          Int        @id @default(autoincrement())
  nombre      String
  codigo      String?
  profesor    String?
  salon       String?
  creditos    Int?
  color       String
  descripcion String?
  userId      Int
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  schedules   Schedule[]
  tasks       Task[]
  notes       Note[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  studyGroups StudyGroup[]

  @@index([userId])
  @@map("subjects")
}

model Schedule {
  id        Int      @id @default(autoincrement())
  dayOfWeek Int
  startTime String
  endTime   String
  classroom String?
  subjectId Int
  subject   Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([subjectId])
  @@map("schedules")
}

model Task {
  id          Int          @id @default(autoincrement())
  title       String
  description String?
  priority    TaskPriority
  status      TaskStatus
  dueDate     DateTime
  completedAt DateTime?
  subjectId   Int
  subject     Subject      @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([subjectId])
  @@map("tasks")
}

model Note {
  id        Int      @id @default(autoincrement())
  title     String
  content   String
  isPinned  Boolean  @default(false)
  subjectId Int
  subject   Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([subjectId])
  @@map("notes")
}

model UserProgress {
  id        Int      @id @default(autoincrement())
  userId    Int      @unique
  level     Int      @default(1)
  xp        Int      @default(0)
  totalXp   Int      @default(0)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("user_progress")
}

model Achievement {
  id          Int                 @id @default(autoincrement())
  code        String              @unique
  nombre      String              @unique
  descripcion String
  category    AchievementCategory @default(TASK)
  icon        String?
  badgeColor  String?
  badgeImage  String?
  xpReward    Int                 @default(0)
  users       UserAchievement[]
  createdAt   DateTime            @default(now())

  @@map("achievements")
}

model UserAchievement {
  userId        Int
  achievementId Int
  unlockedAt    DateTime    @default(now())
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@id([userId, achievementId])
  @@map("user_achievements")
}

model StudyStreak {
  id             Int       @id @default(autoincrement())
  userId         Int       @unique
  currentStreak  Int       @default(0)
  bestStreak     Int       @default(0)
  lastActivityAt DateTime?
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("study_streaks")
}

model XpHistory {
  id        Int          @id @default(autoincrement())
  userId    Int
  amount    Int
  action    XpActionType
  metadata  Json?
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime     @default(now())

  @@index([userId])
  @@map("xp_history")
}

enum NotificationType {
  TASK_DUE
  CLASS_REMINDER
  ROADMAP_REMINDER
  GROUP_SESSION
  JOB_MATCH
  INTERVIEW
  KNOWLEDGE_GAP
  EXAM_ALERT
  STREAK_RISK
}

enum LanguageLevel {
  BASIC
  INTERMEDIATE
  ADVANCED
  NATIVE
}

model Resume {
  id Int @id @default(autoincrement())

  userId Int @unique

  titulo  String?
  resumen String?
  slug    String? @unique

  user User @relation(fields: [userId], references: [id])

  experiences  Experience[]
  projects     Project[]
  educations   Education[]
  certificates Certificate[]
  languages    Language[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("resumes")
}

model Experience {
  id Int @id @default(autoincrement())

  company  String
  position String

  description String?

  startDate DateTime
  endDate   DateTime?

  isCurrent Boolean @default(false)

  resumeId Int
  resume   Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  @@map("experiences")
}

model Education {
  id Int @id @default(autoincrement())

  institution String

  degree String

  startDate DateTime

  endDate DateTime?

  isCurrent Boolean @default(false)

  resumeId Int
  resume   Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  @@map("educations")
}

model Project {
  id Int @id @default(autoincrement())

  title String

  description String

  githubUrl String?

  liveUrl String?

  technologies String[]

  resumeId Int
  resume   Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  @@map("projects")
}

model Certificate {
  id Int @id @default(autoincrement())

  title String

  issuer String

  issueDate DateTime?

  credentialUrl String?

  resumeId Int
  resume   Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  @@map("certificates")
}

model Language {
  id Int @id @default(autoincrement())

  name String

  level LanguageLevel

  resumeId Int

  resume Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  @@map("languages")
}

model Job {
  id              Int               @id @default(autoincrement())
  title           String
  company         String
  description     String
  location        String?
  country         String?
  city            String?
  modality        Modality
  seniority       ProfessionalLevel
  contractType    String?
  salaryMin       Float?
  salaryMax       Float?
  companyLogo     String?
  isRemote        Boolean           @default(false)
  studentFriendly Boolean           @default(false)
  requirements    String[]
  skills          String[]

  source             String?
  sourceUrl          String?
  externalId         String?
  discoveredByUserId Int?

  discoveredBy User? @relation("JobDiscoverer", fields: [discoveredByUserId], references: [id], onDelete: SetNull)

  publishedAt DateTime  @default(now())
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  applications JobApplication[]
  saves        SavedJob[]

  @@map("jobs")
}

model SavedJob {
  id        Int      @id @default(autoincrement())
  userId    Int
  jobId     Int
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  job  Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([userId, jobId])
  @@map("saved_jobs")
}

model JobApplication {
  id            Int                  @id @default(autoincrement())
  userId        Int
  jobId         Int
  status        JobApplicationStatus @default(APPLIED)
  statusHistory Json                 @default("[]")
  appliedAt     DateTime             @default(now())
  notes         String?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  job  Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([userId, jobId])
  @@map("job_applications")
}

model Roadmap {
  id             Int     @id @default(autoincrement())
  userId         Int
  title          String
  description    String?
  category       String?
  difficulty     String?
  estimatedHours Float?
  generatedByAi  Boolean @default(true)
  aiPrompt       Json?

  user  User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  steps RoadmapStep[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("roadmaps")
}

model RoadmapStep {
  id             Int     @id @default(autoincrement())
  roadmapId      Int
  title          String
  description    String?
  order          Int
  skill          String
  skillCategory  String?
  estimatedHours Float?
  completed      Boolean @default(false)

  roadmap Roadmap @relation(fields: [roadmapId], references: [id], onDelete: Cascade)

  @@map("roadmap_steps")
}

model ResumeAnalysis {
  id               Int      @id @default(autoincrement())
  userId           Int
  resumeId         Int? // Opcional si se sube archivo suelto
  score            Float
  atsScore         Float
  strengths        String[]
  weaknesses       String[]
  missingSkills    String[]
  recommendedRoles String[]
  recommendations  String[]
  analyzedAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("resume_analyses")
}

model StudyGroup {
  id          Int      @id @default(autoincrement())
  creatorId   Int
  name        String
  description String?
  subjectId   Int?
  subjectName String?
  password    String?
  maxMembers  Int      @default(20)
  isPublic    Boolean  @default(true)
  createdAt   DateTime @default(now())

  creator       User                @relation("GroupCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  subject       Subject?            @relation(fields: [subjectId], references: [id], onDelete: SetNull)
  members       StudyGroupMember[]
  sessions      StudyGroupSession[]
  groupMessages GroupMessage[]

  @@map("study_groups")
}

model StudyGroupMember {
  id       Int      @id @default(autoincrement())
  groupId  Int
  userId   Int
  role     String   @default("MEMBER")
  joinedAt DateTime @default(now())

  group StudyGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@map("study_group_members")
}

model StudyGroupSession {
  id          Int      @id @default(autoincrement())
  groupId     Int
  title       String
  description String?
  startAt     DateTime
  endAt       DateTime
  createdAt   DateTime @default(now())

  group StudyGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@map("study_group_sessions")
}

model Notification {
  id        Int              @id @default(autoincrement())
  userId    Int
  title     String
  message   String
  type      NotificationType
  read      Boolean          @default(false)
  metadata  Json?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@map("notifications")
}

model AcademicRisk {
  id        Int      @id @default(autoincrement())
  userId    Int
  score     Float
  level     String
  reasons   Json
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("academic_risks")
}

model GroupMessage {
  id        Int      @id @default(autoincrement())
  groupId   Int
  userId    Int
  content   String?
  imageUrl  String?
  createdAt DateTime @default(now())

  group StudyGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([groupId])
  @@map("group_messages")
}
